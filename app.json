{
  "expo": {
    "name": "SharkFit 75",
    "slug": "sharkfit-75",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "sharkfit75",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#06131F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sharkfit75.app",
      "buildNumber": "1",
      "infoPlist": {
        "UIUserInterfaceStyle": "Dark",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Permite escolher uma foto opcional para receitas do SharkFit 75."
      }
    },
    "android": {
      "package": "com.sharkfit75.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06131F"
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECORD_AUDIO"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#38D6F4",
          "defaultChannel": "sharkfit75"
        }
      ],
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "05be3f9c-d202-4178-9a9d-74100ab7be9f"
      }
    }
  }
}
